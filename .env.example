# Copy this file to .env and replace values with your secrets

# MongoDB Atlas connection string
# Example: mongodb+srv://<user>:<password>@cluster0.abcd.mongodb.net/staynest_db?retryWrites=true&w=majority
MONGO_URI=

# JWT secret for signing tokens (use a long random string in production)
JWT_SECRET=your_jwt_secret_here

# Razorpay credentials (if using payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Server port
PORT=5000
# Copy to .env and fill values
PORT=5000
MONGO_URI=YOUR_MONGODB_CONNECTION_STRING
JWT_SECRET=your_jwt_secret_here
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# SMTP / Email settings for booking confirmations (optional)
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USER=your_smtp_user
EMAIL_PASS=your_smtp_password
EMAIL_FROM="StayNest <noreply@staynest.example.com>"
